# Copy to .env and edit for each new server:
#   cp .env.example .env

# --- Mail server identity ---
DOMAIN=example.com
HOSTNAME=smtp0.example.com
EMAIL_USER=info
EMAIL_PASS=ChangeMe123!

# --- Timezone ---
TZ=Asia/Kolkata

# --- Admin panel (http://YOUR_IP:8090) ---
ADMIN_PASSWORD=ChangeAdminPass!
ADMIN_SECRET=change-this-secret-in-production

# --- Let's Encrypt (hostname must resolve to this server) ---
CERTBOT_EMAIL=info@example.com
CERTBOT_DOMAIN=smtp0.example.com
