# Copy to .env and edit for each new server:
#   cp .env.example .env
#
# Domains and mail accounts are created via the admin panel (port 8090).

# --- Mail server hostname (SMTP PTR/MX, TLS certificate) ---
HOSTNAME=smtp0.example.com

# --- Timezone ---
TZ=Asia/Kolkata

# --- Admin panel (http://YOUR_IP:8090) ---
ADMIN_PASSWORD=ChangeAdminPass!
ADMIN_SECRET=change-this-secret-in-production

# --- Let's Encrypt (uses HOSTNAME above; contact email below) ---
CERTBOT_EMAIL=admin@example.com
